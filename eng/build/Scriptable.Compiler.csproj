<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net6.0</TargetFramework>
    <RootNamespace>Scriptable.Compiler</RootNamespace>
    <NoWarn>CS0649;CS0169</NoWarn>
    <NukeRootDirectory>..</NukeRootDirectory>
    <NukeScriptDirectory>..</NukeScriptDirectory>
    <NukeTelemetryVersion>1</NukeTelemetryVersion>
    <AssemblyName>Scriptable.Compiler</AssemblyName>
    <Nullable>enable</Nullable>
    <RepositoryType>git</RepositoryType>
    <RepositoryUrl>https://github.com/jessenich/scriptable</RepositoryUrl>
    <PackageProjectUrl>https://github.com/jessenich/scriptable/main/README.md</PackageProjectUrl>
    <Copyright>Copyright (c) 2021 Jesse N. All Rights Reserved</Copyright>
    <PackageTags>shell;bash;zsh;cmd;pwsh;powershell;commandline;cli;script;scripts;shebang</PackageTags>
    <AssemblyVersion>$(Version)</AssemblyVersion>
    <FileVersion>$(Version)</FileVersion>
    <Version>$(Version)</Version>
    <PackageLicenseFile>LICENSE</PackageLicenseFile>
  </PropertyGroup>

  <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Debug|AnyCPU'">
    <PlatformTarget>AnyCPU</PlatformTarget>
    <DefineConstants>NETCORE_COMPILER</DefineConstants>
    <Optimize>True</Optimize>
    <CheckForOverflowUnderflow>True</CheckForOverflowUnderflow>
  </PropertyGroup>

  <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Release|AnyCPU'">
    <PlatformTarget>AnyCPU</PlatformTarget>
    <DefineConstants>NETCORE_COMPILER</DefineConstants>
    <Optimize>False</Optimize>
    <CheckForOverflowUnderflow>True</CheckForOverflowUnderflow>
  </PropertyGroup>

  <ItemGroup>
    <Content Include="..\..\.nuke\build.schema.json" Link="build.schema.json" />
    <Content Include="..\..\.nuke\parameters.json" Link="parameters.json" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Nuke.Common" Version="5.2.1" />
  </ItemGroup>

</Project>
